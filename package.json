{
  "name": "@phantom/sdk-monorepo",
  "private": true,
  "packageManager": "yarn@4.2.2",
  "scripts": {
    "clean": "rimraf .turbo node_modules/.cache packages/*/dist examples/*/dist examples/*/.next",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:packages:clean": "turbo run build --filter='./packages/*' --force",
    "build": "turbo run build",
    "build:clean": "turbo run build --force",
    "watch:packages": "turbo watch build --filter='./packages/*'",
    "pack-release": "yarn workspaces foreach --all --topological-dev run pack-release",
    "prettier": "prettier . --write",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "release": "yarn build && yarn pack-release && yarn changeset publish",
    "test": "turbo run test",
    "check-package-configs": "node scripts/check-package-configs.mjs",
    "ci:verify": "turbo run build lint check-types test"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29",
    "turbo": "^2.6.3",
    "typescript": "^5.8.3"
  }
}
