{
  "name": "@phantom/cli",
  "version": "1.2.1",
  "description": "Phantom CLI — interact with your Phantom wallet from the terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantom/phantom-connect-sdk",
    "directory": "packages/cli"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "phantom": "./dist/bin.js"
  },
  "scripts": {
    "?pack-release": "When https://github.com/changesets/changesets/issues/432 has a solution we can remove this trick",
    "pack-release": "rimraf ./_release && yarn pack && mkdir ./_release && tar zxvf ./package.tgz --directory ./_release && rm ./package.tgz",
    "postinstall": "patch-package",
    "build": "rimraf ./dist && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@phantom/api-key-stamper": "workspace:^",
    "@phantom/auth2": "workspace:^",
    "@phantom/base64url": "workspace:^",
    "@phantom/client": "workspace:^",
    "@phantom/constants": "workspace:^",
    "@phantom/crypto": "workspace:^",
    "@phantom/parsers": "workspace:^",
    "@phantom/perps-client": "workspace:^",
    "@phantom/phantom-api-client": "workspace:^",
    "@phantom/sdk-types": "workspace:^",
    "@phantom/utils": "workspace:^",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.5",
    "axios": "^1.6.7",
    "bs58": "^6.0.0",
    "incur": "0.4.1",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.47.16",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "8.53.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.2",
    "tsup": "^6.7.0",
    "typescript": "^5.0.4"
  },
  "publishConfig": {
    "directory": "_release/package"
  }
}
