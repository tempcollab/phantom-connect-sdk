{
  "name": "@phantom/perps-client",
  "version": "1.2.0",
  "description": "Hyperliquid perpetuals client for Phantom Wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantom/phantom-connect-sdk",
    "directory": "packages/perps-client"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "?pack-release": "When https://github.com/changesets/changesets/issues/432 has a solution we can remove this trick",
    "pack-release": "rimraf ./_release && yarn pack && mkdir ./_release && tar zxvf ./package.tgz --directory ./_release && rm ./package.tgz",
    "build": "rimraf ./dist && tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "tsc --noEmit && eslint --cache src",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "eslint": "10.2.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "tsup": "^6.7.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@phantom/client": "workspace:^",
    "@phantom/parsers": "workspace:^",
    "@phantom/phantom-api-client": "workspace:^",
    "axios": "1.15.1",
    "js-sha3": "^0.9.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "directory": "_release/package"
  }
}
